@startuml
title Flutter + Dart 知识图谱教学系统核心类图（v3）

skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultFontName Microsoft YaHei
skinparam classAttributeIconSize 0
skinparam ArrowColor #444444
skinparam ArrowThickness 1.2
skinparam packageStyle rectangle
skinparam package {
  BorderColor #6C8EF5
  BackgroundColor #F8FAFF
  RoundCorner 18
}
skinparam class {
  BorderColor #6C8EF5
  BackgroundColor #FFFFFF
  RoundCorner 12
}

package "Flutter UI Layer" {
  class MyApp {
    +build(context)
  }

  class LoginPage
  class HomePage {
    -_selectedIndex : int
    +build(context)
    -_buildBody()
    -_buildHome()
  }

  class GraphListPage {
    -_graphs : List<GraphModel>
    -_isLoading : bool
    -_loadGraphs() : Future<void>
    +build(context)
  }

  class GraphDetailPage {
    -_nodes : List<NodeModel>
    -_edges : List<EdgeModel>
    -_selectedNode : NodeModel?
    -_isLoading : bool
    -_loadGraphData() : Future<void>
    -_buildGraphView()
    -_buildNodeDetail()
    -_calculateNodePositions() : List<NodeModel>
    -_handleTap(position)
    +build(context)
  }

  class GraphPainter {
    -nodes : List<NodeModel>
    -edges : List<EdgeModel>
    -selectedNode : NodeModel?
    +paint(canvas, size)
    +shouldRepaint(oldDelegate) : bool
  }

  class DocumentListPage {
    -_pdfs : List<Map<String,dynamic>>
    -_ppts : List<Map<String,dynamic>>
    -_loadDocuments() : Future<void>
    +build(context)
  }

  class VideoListPage {
    -_videos : List<Map<String,dynamic>>
    -_loadVideos() : Future<void>
    -_playVideo(video)
    +build(context)
  }

  class QuizPage {
    -_chapters : List<String>
    -_questions : List<QuestionModel>
    -_selectedChapter : String?
    -_currentIndex : int
    -_correctCount : int
    -_quizStarted : bool
    -_loadChapters() : Future<void>
    -_startQuiz(chapter) : Future<void>
    -_submitAnswer()
    -_nextQuestion()
    -_finishQuiz() : Future<void>
    +build(context)
  }

  class ProgressPage {
    -_results : List<QuizResultModel>
    -_quizSummary : Map<String,dynamic>
    -_learningStats : Map<String,dynamic>
    -_loadData() : Future<void>
    +build(context)
  }

  class FavoritesPage {
    -_favorites : List<Map<String,dynamic>>
    -_loadData() : Future<void>
    -_removeFavorite(nodeId) : Future<void>
    +build(context)
  }
}

MyApp --> LoginPage
LoginPage --> AuthService
HomePage --> GraphListPage
HomePage --> QuizPage
HomePage --> VideoListPage
HomePage --> DocumentListPage
HomePage --> ProgressPage
HomePage --> FavoritesPage

GraphListPage --> GraphDao
GraphListPage --> GraphModel

GraphDetailPage --> GraphDao
GraphDetailPage --> FavoriteDao
GraphDetailPage --> LearningRecordDao
GraphDetailPage --> NodeModel
GraphDetailPage --> EdgeModel
GraphDetailPage --> GraphPainter

QuizPage --> QuizDao
QuizPage --> QuestionModel
QuizPage --> QuizResultModel
ProgressPage --> QuizDao
ProgressPage --> LearningRecordDao
ProgressPage --> QuizResultModel
FavoritesPage --> FavoriteDao

AuthService --> UserDao
AuthService --> UserModel

UserDao --> DatabaseHelper
GraphDao --> DatabaseHelper
QuizDao --> DatabaseHelper
FavoriteDao --> DatabaseHelper
LearningRecordDao --> DatabaseHelper

GraphDao ..> GraphModel
GraphDao ..> NodeModel
GraphDao ..> EdgeModel
QuizDao ..> QuestionModel
QuizDao ..> QuizResultModel
UserDao ..> UserModel

DatabaseHelper ..> UserModel
DatabaseHelper ..> GraphModel
DatabaseHelper ..> NodeModel
DatabaseHelper ..> EdgeModel
DatabaseHelper ..> QuestionModel
DatabaseHelper ..> QuizResultModel

note right of GraphDetailPage
核心图谱交互页面：
1. 加载 nodes / edges
2. 计算节点布局
3. 支持缩放拖拽
4. 点击节点查看详情
5. 触发学习与收藏动作
end note

note bottom of DatabaseHelper
统一管理 SQLite 初始化：
- users
- current_session
- graphs
- nodes
- edges
- questions
- quiz_results
- learning_records
- favorites
- resource_files
end note

@enduml
