*.key
*.pem
*.p12
key.properties
google-services.json
GoogleService-Info.plist

docs/分层架构HelloWorldAndroid版AI问答系统/

# Office 临时锁文件
~$*

# 4 端发布产物 zip 包（按 CLAUDE.md 部署产物规则放在 dist/）
dist/
lib.backup/
pubspec_overrides.yaml

# Claude Code 本地配置（settings.local.json 含本地路径白名单 / worktrees 是本地状态）
.claude/*
!.claude/skills/

# ── IDE / 工具临时缓存（不该入库） ──
.cursor-plugin/
.omm/
.flutter-plugins
/android/build/

# ── 编译/调试残留 ──
nuget.exe
ohos_build_log.txt
*_temp.xlsx
test/screenshots/failures/

# ── 归档输出（一键归档落盘 docx + zip）──
/archive_out/

# ── Python 字节码缓存 ──
__pycache__/

# ── Android AVD 自动生成 ──
avd_features.ini

# ── 运行时数据（不追踪）──
/live/

# ── Gitee 学生同步数据（BOT 自动生成，不得入 Git 历史）──
/sync/

# ── 旧 Web Server 构建（已移除）──
/web_server/

# ── 旧 OHOS 覆盖方案（已移除）──
/ohos_overrides/

# ── 草稿 / 计划文档 ──
/drafts/
data/达成/
sqlite-autoconf-*.zip
